# Copy to .env and fill in. Never commit .env.
# Format: one KEY=value per line, NO spaces around =. Use double quotes if value has # or spaces.
# Aura: https://neo4j.com/cloud/aura/ → create DB → copy URI and password.

NEO4J_URI="neo4j+s://xxxxxxxx.databases.neo4j.io"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your_password_here"

# Optional (default: ./chronicle_graph_project)
# CHRONICLE_GRAPH_PROJECT="./chronicle_graph_project"

# Optional Postgres backend convergence work.
# Copy .env.postgres.example to .env.postgres.local for local Docker bootstrap.
# CHRONICLE_EVENT_STORE=postgres
# CHRONICLE_POSTGRES_URL="postgresql://chronicle:chronicle_dev_password@127.0.0.1:5432/chronicle"
